PORT=3000

# Postgres connection string.
# On Railway: reference the Postgres service — DATABASE_URL=${{Postgres.DATABASE_URL}}
# Locally: use the service's PUBLIC connection URL (SSL is auto-enabled for it).
DATABASE_URL=postgresql://user:password@host:5432/railway

# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Recipient email(s) for the daily digest (comma-separated for multiple)
NOTIFY_EMAIL=you@example.com,another@example.com

# Timezone for 9am cron (IANA name)
TZ=America/New_York

# Public URL of the deployed app — used for the "Open app" link in the digest email.
# Set this to your Railway URL (e.g. https://kids-scheduler.up.railway.app) so the link
# works on mobile. Defaults to http://localhost:3000 if unset.
APP_URL=https://your-app.up.railway.app
